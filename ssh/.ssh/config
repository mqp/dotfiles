CanonicalizeHostname yes
CanonicalDomains flicker-neon.ts.net

Host github.com
  HostName github.com
  User git
  RequestTTY no
  PreferredAuthentications publickey
  IdentityFile ~/.ssh/polrs.ecdsa
  ControlMaster auto
  ControlPath ~/.ssh/sockets/%r@%n:%p
  ControlPersist yes
  ServerAliveInterval 60

Host git.sr.ht
  User git
  RequestTTY no
  PreferredAuthentications publickey
  IdentityFile ~/.ssh/polrs.ecdsa
  ControlMaster auto
  ControlPath ~/.ssh/sockets/%r@%n:%p
  ControlPersist yes
  ServerAliveInterval 60

Host dica.city
  User mqp
  ForwardAgent yes
  PreferredAuthentications publickey
  IdentityFile ~/.ssh/polrs.ecdsa
  ServerAliveInterval 5

Host rsyncnet
  HostName de4165.rsync.net
  User de4165
  PreferredAuthentications publickey
  IdentityFile ~/.ssh/polrs.ecdsa

Host *.manifold.markets
  User marshall_pol_rs
  PreferredAuthentications publickey
  IdentityFile ~/.ssh/polrs.ecdsa

Host pinkmoon.lan
  User root
  PreferredAuthentications password,keyboard-interactive
  ServerAliveInterval 1

Host *.ts.net *.lan *.pol.rs pol.rs
  User mqp
  PreferredAuthentications publickey,password,keyboard-interactive
  IdentityFile ~/.ssh/polrs.ecdsa
  ServerAliveInterval 1

Host notadoctor.ai themulti.ai
  User mqp
  Port 34836
  IdentityFile ~/.ssh/polrs.ecdsa

Host *
  Compression yes
  IdentitiesOnly yes
  AddressFamily any
  Protocol 2
